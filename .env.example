# Telegram bot tokeni
BOT_TOKEN=your_bot_token_here

# Admin Telegram ID (vergul bilan bir nechta bo'lishi mumkin)
OWNER_ID=123456789

# SQLite database fayl yo'li
# Persistent disk ulangan bo'lsa shu yo'lni ko'rsating:
# Masalan Railway: DB_PATH=/data/bot.db
# Masalan Render:  DB_PATH=/opt/render/project/src/data/bot.db
# Agar bo'sh qolsa, odatiy bot.db (container ichida, data o'chadi!)
DB_PATH=/data/bot.db
